{
  "manifest_version": 3,
  "name": "Duck Hunt",
  "version": "1.3",
  "description": "Quack! Analyze any job posting instantly — fit score, cover letter bullets, and add it to your pond.",
  "permissions": ["activeTab", "storage", "scripting"],
  "icons": {
    "16":  "icon16.png",
    "32":  "icon32.png",
    "48":  "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Analyze this job",
    "default_icon": {
      "16":  "icon16.png",
      "32":  "icon32.png",
      "48":  "icon48.png",
      "128": "icon128.png"
    }
  }
}
